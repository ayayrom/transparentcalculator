<h1>Transparent Calculator</h1>
<p>Find me in app/views/calculations/new.html.erb</p>

<% if @calculation.errors.any? %>
  <div style="color: red;" id="server_error_box">
    <%= @calculation.errors.full_messages.to_sentence %>
  </div>
<% end %>

<%= form_with model: @calculation, local: true do |form| %>
  <div>
    <%= form.label :equation, "Enter your math equation:" %>
    <%= form.text_field :equation,
      id: "equation_input",
      size: 50,
      placeholder: "(10^10 + (10 * 10)^10) + 10",
      required: true,
      pattern: '[0-9\+\*\/\^\(\)\.\s\-]+', # bruh this was so strict so i brute forced it
      title: "Only numbers, spaces, and math operators (+, -, *, /, ^) are allowed."
     %>
  </div>

  <br>

  <div>
    <%= form.submit "Calculate steps",
        id: "calculate_btn",
        disabled: @calculation.errors.any? %>
  </div>
<% end %>

<script>
  {
    const input = document.getElementById("equation_input");
    const button = document.getElementById("calculate_btn");
    const errorBox = document.getElementById("server_error_box");

    // once the page loads, add the hooks
    if (input && button) {
      const rejectedValue = input.value;

      const validateInput = () => {
        if (errorBox &&
            errorBox.style.display !== "none" &&
            input.value === rejectedValue) {
          button.disabled = true;
          return;
        }
        button.disabled = !input.checkValidity();
      };

      validateInput();

      input.addEventListener("input", () => {
        if (errorBox && input.value !== rejectedValue) {
          errorBox.style.display = "none";
        }
        validateInput();
      });
    }
  }
</script>
